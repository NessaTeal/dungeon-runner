[internationalization]

locale/translations=PackedStringArray("res://Localization/translations.en.translation")

[layer_names]

3d_physics/layer_1="Player"
3d_physics/layer_2="Enemy"
3d_physics/layer_3="Ground"
3d_physics/layer_4="Collectible"
3d_physics/layer_5="EnemyCollisionDamage"
3d_physics/layer_6="EnemySelfCollision"
3d_physics/layer_7="PlayerAttacks"
3d_physics/layer_8="EnemyHurtbox"
3d_physics/layer_9="Walls"
3d_physics/layer_10="CollectibleMagnet"

[physics]

common/physics_ticks_per_second=120
3d/physics_engine="Jolt Physics"
jolt_physics_3d/limits/max_bodies=20480

[rendering]

rendering_device/staging_buffer/block_size_kb=4096
rendering_device/staging_buffer/max_size_mb=256
renderer/rendering_method.mobile="gl_compatibility"
textures/default_filters/anisotropic_filtering_level=4
anti_aliasing/quality/msaa_3d=3
anti_aliasing/quality/screen_space_aa=2
anti_aliasing/quality/use_taa=true

[threading]

worker_pool/max_threads=8
